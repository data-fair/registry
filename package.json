{
  "name": "registry",
  "version": "0.1.3",
  "description": "A simple registry for the data-fair stack containing plugin definitions and hosting archives of versions.",
  "type": "module",
  "scripts": {
    "test": "playwright test --project=unit --max-failures=1 && playwright test --project=api --max-failures=1 && playwright test --project=e2e --max-failures=1",
    "lint": "eslint . && npm -w ui run lint",
    "lint-fix": "eslint --fix . && npm -w ui run lint-fix",
    "dev-api": "npm -w api run dev",
    "dev-ui": "npm -w ui run dev",
    "dev-deps": "mkdir -p dev/logs && docker compose up 2>&1 | tee dev/logs/docker-compose.log",
    "dev-zellij": "dotenv -- zellij --layout .zellij.kdl",
    "dev:fixtures": "dotenv -- node --experimental-strip-types --no-warnings=ExperimentalWarning dev/fixtures.ts",
    "build-lib-node": "tsc -p tsconfig.build.json",
    "build-types": "mkdir -p ui/src/components/vjsf && df-build-types . --vjsf-dir ui/src/components/vjsf",
    "prepare": "husky || true",
    "check-types": "tsc && npm -w ui run check-types",
    "quality": "npm run lint && npm run build-types && npm run check-types && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/data-fair/registry.git"
  },
  "workspaces": [
    "ui",
    "api",
    "shared",
    "lib-node"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/data-fair/registry/issues"
  },
  "homepage": "https://github.com/data-fair/registry#readme",
  "devDependencies": {
    "@commitlint/config-conventional": "^19.2.2",
    "@data-fair/lib-express": "^1.19.0",
    "@data-fair/lib-node": "^2.8.1",
    "@koumoul/vjsf-compiler": "^1.2.3",
    "@playwright/test": "^1.58.2",
    "@reporters/bail": "^1.2.1",
    "@types/config": "^3.3.5",
    "@types/express": "^5.0.6",
    "@types/busboy": "^1.5.0",
    "@types/node": "^22.12.0",
    "@types/semver": "^7.5.0",
    "@types/tar-stream": "^3.1.0",
    "commitlint": "^19.2.2",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.10.0",
    "eslint-plugin-vue": "^10.5.0",
    "eslint-plugin-vuetify": "^2.5.1",
    "husky": "^9.1.6",
    "neostandard": "^0.12.2",
    "nodemon": "^3.1.14",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@data-fair/lib-types-builder": "^1.8.3",
    "@types/debug": "^4.1.12",
    "ajv": "^8.17.1",
    "form-data": "^4.0.0",
    "tough-cookie": "^5.1.2",
    "ufo": "^1.6.3"
  }
}
