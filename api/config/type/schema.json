{
  "$id": "https://github.com/data-fair/registry/api/config",
  "x-exports": [
    "types",
    "validate"
  ],
  "x-ajv": {
    "coerceTypes": "array"
  },
  "type": "object",
  "title": "Api config",
  "additionalProperties": false,
  "required": [
    "privateDirectoryUrl",
    "mongoUrl",
    "port",
    "tmpDir",
    "observer",
    "secretKeys"
  ],
  "properties": {
    "mongoUrl": {
      "type": "string"
    },
    "port": {
      "type": "number"
    },
    "tmpDir": {
      "type": "string"
    },
    "dataDir": {
      "type": "string"
    },
    "maxUploadBytes": {
      "type": "integer",
      "default": 524288000,
      "description": "Maximum accepted size in bytes for a single uploaded artefact (tarball or raw file)."
    },
    "privateDirectoryUrl": {
      "type": "string",
      "pattern": "^https?://"
    },
    "privateEventsUrl": {
      "type": "string"
    },
    "secretKeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "events": {
          "type": "string"
        },
        "internalServices": {
          "type": "string"
        }
      }
    },
    "observer": {
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean"
        },
        "port": {
          "type": "number"
        }
      }
    },
    "filesStorage": {
      "type": "string",
      "enum": ["fs", "s3"],
      "default": "fs"
    },
    "s3": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region": { "type": "string" },
        "endpoint": { "type": "string" },
        "bucket": { "type": "string" },
        "credentials": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "accessKeyId": { "type": "string" },
            "secretAccessKey": { "type": "string" }
          }
        },
        "forcePathStyle": { "type": "boolean" },
        "downloadUrlExpirySeconds": {
          "type": "integer",
          "minimum": 60,
          "default": 900,
          "description": "Expiry in seconds for S3 presigned download URLs issued by the /download and /tarball routes."
        }
      }
    },
    "upgradeRoot": {
      "type": "string"
    },
    "util": {},
    "get": {},
    "has": {}
  }
}
